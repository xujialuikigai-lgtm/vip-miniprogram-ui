/* 管理端订单详情样式 */
.page-admin-order-detail {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 32rpx;
}

/* 加载 / 异常占位 */
.state-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.state-text {
  margin: 24rpx 0 32rpx;
  font-size: 28rpx;
  color: #999999;
}

.state-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #eef2f6;
  color: #8a95a5;
  font-size: 48rpx;
  font-weight: 900;
}

/* 状态头部 */
.hero {
  margin: 24rpx;
  padding: 32rpx 36rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #3a342a 0%, #1f1c17 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 28, 23, 0.2);
}

.hero__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero__product {
  flex: 1;
  margin-right: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #f5d9a0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero__pkg {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 失败原因 */
.hero__fail {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background-color: rgba(244, 67, 54, 0.16);
}

.hero__fail-icon {
  flex-shrink: 0;
  color: #ffb4a8;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.5;
}

.hero__fail-text {
  margin-left: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #ffb4a8;
}

/* 金额指标 */
.hero__metrics {
  display: flex;
  margin-top: 32rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}

.metric {
  flex: 1;
  text-align: center;
}

.metric--mid {
  border-left: 1rpx solid rgba(255, 255, 255, 0.12);
  border-right: 1rpx solid rgba(255, 255, 255, 0.12);
}

.metric__value {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.metric__value--profit {
  color: #7ed4a0;
}

.metric__value--loss {
  color: #ff8a80;
}

.metric__label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 通用卡片 */
.card {
  margin: 24rpx;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
}

.card__title {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row__label {
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
}

.info-row__value {
  display: flex;
  align-items: center;
}

.info-row__text {
  font-size: 26rpx;
  color: #333333;
  margin-right: 8rpx;
  word-break: break-all;
  text-align: right;
}

.copy-mark {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #fff4ce;
  color: #8b641b;
  font-size: 22rpx;
  font-weight: 800;
}

/* 接口调用日志 */
.logs__empty {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  padding: 24rpx 0;
}

.log-item {
  padding: 20rpx;
  margin-bottom: 16rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  border-left: 6rpx solid #c99a3a;
}

.log-item:last-child {
  margin-bottom: 0;
}

.log-item__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.log-item__time {
  font-size: 24rpx;
  color: #666666;
}

.log-item__code {
  font-size: 22rpx;
  color: #c99a3a;
}

.log-item__desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #333333;
  word-break: break-all;
}

.log-item__duration {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999999;
}

/* 底部占位与固定操作栏 */
.bottom-placeholder {
  height: 140rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.footer__btn {
  flex: 1;
}

/* 退款表单弹窗 */
.refund-form {
  padding: 40rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background-color: #ffffff;
}

.refund-form__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  text-align: center;
}

.refund-form__tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

.refund-form__section-label {
  margin: 28rpx 0 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
}

.refund-form__actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.refund-form__btn {
  flex: 1;
}
