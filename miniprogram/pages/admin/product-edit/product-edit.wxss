/* 管理端商品编辑样式 */
.page-admin-product-edit {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 状态盒子 */
.state-box {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

/* 区块 */
.section {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.req {
  color: #f44336;
  margin-left: 4rpx;
}

/* 普通字段行 */
.field {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.field.no-border {
  border-bottom: none;
}

.field-label {
  width: 200rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.field-control {
  flex: 1;
  display: flex;
  align-items: center;
}

.control-right {
  justify-content: flex-end;
}

.ipt {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.counter {
  font-size: 22rpx;
  color: #999;
  margin-left: 12rpx;
}

.value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #bbb;
}

.arrow {
  margin-left: 10rpx;
  color: #ccc;
  font-size: 36rpx;
}

/* 新增套餐按钮 */
.add-btn {
  font-size: 26rpx;
  color: #c99a3a;
  font-weight: 500;
}

.pkg-empty,
.popup-empty {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}

/* 套餐卡片 */
.pkg-card {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.pkg-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pkg-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.pkg-type {
  font-size: 24rpx;
  color: #999;
}

.pkg-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.price-now {
  font-size: 32rpx;
  color: #c99a3a;
  font-weight: 600;
}

.price-cost {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.pkg-ops {
  display: flex;
  gap: 28rpx;
}

.op-edit {
  font-size: 26rpx;
  color: #c99a3a;
}

.op-del {
  font-size: 26rpx;
  color: #f44336;
}

.loss-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #f44336;
}

/* 售前规则 */
.rule-field {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.rule-field:last-child {
  border-bottom: none;
}

.txt {
  width: 100%;
  box-sizing: border-box;
  margin-top: 12rpx;
  min-height: 120rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #333;
}

.bottom-placeholder {
  height: 40rpx;
}

/* 底部操作栏 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.footer-btn.preview {
  background: #f5f0e6;
  color: #c99a3a;
}

.footer-btn.save {
  background: #c99a3a;
  color: #fff;
}

.footer-btn.save.disabled {
  opacity: 0.6;
}

/* 弹窗通用 */
.popup {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.popup-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.popup-close {
  font-size: 26rpx;
  color: #999;
  font-weight: 400;
}

.popup-list {
  max-height: 60vh;
}

.popup-item {
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #f5f5f5;
}

.popup-item.active {
  color: #c99a3a;
  font-weight: 600;
}

/* 套餐弹窗表单 */
.pkg-popup {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.pkg-form {
  padding: 0 32rpx;
  overflow-y: auto;
}

.pkg-save-btn {
  margin: 24rpx 32rpx 0;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #c99a3a;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
}
