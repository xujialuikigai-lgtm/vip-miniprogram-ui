/* 管理端商品编辑样式 */
.page-admin-product-edit {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background:
    linear-gradient(rgba(20, 184, 166, 0.04) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(20, 184, 166, 0.04) 1rpx, transparent 1rpx),
    #f5f7f8;
  background-size: 40rpx 40rpx;
}

.state-box {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.edit-hero {
  position: relative;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 18rpx;
  background:
    radial-gradient(circle at 80% 12%, rgba(25, 181, 155, 0.32) 0, rgba(25, 181, 155, 0) 34%),
    linear-gradient(135deg, #113d3c 0%, #08242a 100%);
  color: #f8fbfb;
  box-shadow: 0 20rpx 42rpx rgba(8, 36, 42, 0.18);
}

.edit-hero__title {
  font-size: 38rpx;
  font-weight: 800;
}

.edit-hero__desc {
  margin-top: 10rpx;
  width: 70%;
  color: rgba(248, 251, 251, 0.82);
  font-size: 25rpx;
  line-height: 1.5;
}

.edit-hero__status {
  position: absolute;
  right: 28rpx;
  top: 30rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.edit-hero__status.is-online {
  background: #ddf8ee;
  color: #0d9b7e;
}

.edit-hero__status.is-offline {
  background: rgba(255, 255, 255, 0.14);
  color: #d5dee9;
}

.section {
  margin: 20rpx 24rpx;
  padding: 26rpx;
  border-radius: 18rpx;
  background: #fbfcfd;
  box-shadow: 0 14rpx 36rpx rgba(21, 32, 51, 0.05);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  color: #17202f;
  font-size: 32rpx;
  font-weight: 800;
}

.req {
  color: #df4f43;
  margin-left: 4rpx;
}

.field {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.field.no-border {
  border-bottom: none;
}

.field-label {
  width: 206rpx;
  flex-shrink: 0;
  color: #526071;
  font-size: 27rpx;
  font-weight: 700;
}

.field-control {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.control-right {
  justify-content: flex-end;
}

.ipt {
  flex: 1;
  min-width: 0;
  color: #17202f;
  font-size: 28rpx;
  text-align: right;
}

.counter {
  margin-left: 12rpx;
  color: #8a95a5;
  font-size: 22rpx;
}

.value {
  flex: 1;
  color: #17202f;
  font-size: 28rpx;
  font-weight: 700;
  text-align: right;
}

.placeholder {
  flex: 1;
  color: #a7b1bf;
  font-size: 28rpx;
  text-align: right;
}

.arrow {
  margin-left: 10rpx;
  color: #a7b1bf;
  font-size: 38rpx;
}

.add-btn {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1bf;
  color: #8b641b;
  font-size: 24rpx;
  font-weight: 800;
}

.pkg-empty,
.popup-empty {
  padding: 44rpx 0;
  color: #8a95a5;
  font-size: 26rpx;
  text-align: center;
}

.pkg-card {
  margin-top: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #e6ecf2;
  border-radius: 16rpx;
  background: #ffffff;
}

.pkg-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.pkg-name {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  color: #17202f;
  font-size: 29rpx;
  font-weight: 800;
}

.pkg-type {
  flex-shrink: 0;
  color: #617084;
  font-size: 24rpx;
}

.pkg-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  gap: 18rpx;
}

.pkg-price {
  min-width: 0;
}

.price-now {
  color: #9a6c13;
  font-size: 34rpx;
  font-weight: 800;
}

.price-cost {
  margin-left: 16rpx;
  color: #8a95a5;
  font-size: 24rpx;
}

.pkg-ops {
  display: flex;
  flex-shrink: 0;
  gap: 22rpx;
}

.op-edit,
.op-del {
  font-size: 25rpx;
  font-weight: 800;
}

.op-edit {
  color: #8b641b;
}

.op-del {
  color: #df4f43;
}

.pending-tip {
  margin-top: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: #fff7e7;
  color: #8b641b;
  font-size: 23rpx;
}

.loss-tip {
  margin-top: 12rpx;
  color: #df4f43;
  font-size: 24rpx;
}

.rule-field {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.rule-field:last-child {
  border-bottom: none;
}

.txt {
  box-sizing: border-box;
  width: 100%;
  min-height: 124rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f5f7f8;
  color: #17202f;
  font-size: 26rpx;
  line-height: 1.55;
}

.bottom-placeholder {
  height: 40rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 18rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fbfcfd;
  box-shadow: 0 -8rpx 28rpx rgba(21, 32, 51, 0.06);
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 14rpx;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 88rpx;
  text-align: center;
}

.footer-btn.preview {
  border: 1rpx solid #dfe6ed;
  background: #ffffff;
  color: #526071;
}

.footer-btn.save {
  background: linear-gradient(180deg, #f8d971 0%, #e7b940 100%);
  color: #6d4a0d;
}

.footer-btn.save.disabled {
  opacity: 0.6;
}

.popup {
  display: flex;
  flex-direction: column;
  max-height: 80vh;
  border-radius: 28rpx 28rpx 0 0;
  background: #fbfcfd;
}

.popup-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 32rpx;
  border-bottom: 1rpx solid #edf1f5;
  color: #17202f;
  font-size: 31rpx;
  font-weight: 800;
}

.popup-close {
  color: #617084;
  font-size: 26rpx;
  font-weight: 700;
}

.popup-list {
  max-height: 60vh;
}

.popup-item {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #edf1f5;
  color: #17202f;
  font-size: 28rpx;
}

.popup-item.active {
  color: #8b641b;
  font-weight: 800;
}

.pkg-popup {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.pkg-form {
  padding: 0 32rpx;
  overflow-y: auto;
}

.pkg-save-btn {
  height: 88rpx;
  margin: 24rpx 32rpx 0;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #f8d971 0%, #e7b940 100%);
  color: #6d4a0d;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 88rpx;
  text-align: center;
}
