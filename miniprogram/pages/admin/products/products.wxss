/* 管理端商品运营列表页样式 */
.page-products {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background:
    linear-gradient(rgba(20, 184, 166, 0.04) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(20, 184, 166, 0.04) 1rpx, transparent 1rpx),
    #f5f7f8;
  background-size: 40rpx 40rpx;
  --td-brand-color: #c99a3a;
}

.ops-hero {
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 18rpx;
  background:
    radial-gradient(circle at 80% 12%, rgba(25, 181, 155, 0.32) 0, rgba(25, 181, 155, 0) 34%),
    linear-gradient(135deg, #113d3c 0%, #08242a 100%);
  color: #f8fbfb;
  box-shadow: 0 20rpx 42rpx rgba(8, 36, 42, 0.18);
}

.ops-hero__title {
  font-size: 38rpx;
  font-weight: 800;
  color: #f8fbfb;
}

.ops-hero__desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: rgba(248, 251, 251, 0.82);
}

.overview {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 28rpx;
}

.overview__item {
  min-width: 0;
  padding: 18rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.12);
}

.overview__num {
  font-size: 38rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.2;
}

.overview__num--on {
  color: #bff5df;
}

.overview__num--off {
  color: #d5dee9;
}

.overview__label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 26rpx;
}

.actions__btn {
  flex: 1;
  height: 76rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 76rpx;
  padding: 0;
}

.actions__btn::after {
  border: none;
}

.actions__btn--gold {
  background: linear-gradient(180deg, #f8d971 0%, #e7b940 100%);
  color: #6d4a0d;
}

.actions__btn--plain {
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.12);
  color: #f8fbfb;
}

.actions__btn--danger {
  border: 1rpx solid rgba(228, 92, 79, 0.6);
  background: rgba(228, 92, 79, 0.14);
  color: #ff8a7e;
}

.pkg-badge {
  display: inline-block;
  margin-left: 10rpx;
  padding: 0 12rpx;
  height: 32rpx;
  line-height: 32rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #c99a3a;
  background: rgba(201, 154, 58, 0.12);
  border: 1rpx solid rgba(201, 154, 58, 0.35);
  border-radius: 8rpx;
  vertical-align: middle;
}

.products-tabs {
  position: sticky;
  top: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 0 24rpx 18rpx;
  background: rgba(245, 247, 248, 0.96);
  backdrop-filter: blur(12rpx);
}

.products-tab {
  height: 64rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #566276;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
}

.products-tab--active {
  border: 1rpx solid #eac86f;
  background: #fff4ce;
  color: #8b641b;
}

.container {
  padding: 0 24rpx;
}

.product-card {
  margin-bottom: 20rpx;
  padding: 26rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(21, 32, 51, 0.05);
}

.product-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.product-card__name {
  flex: 1;
  min-width: 0;
  font-size: 31rpx;
  font-weight: 800;
  color: #17202f;
  line-height: 1.35;
}

.product-card__status {
  flex-shrink: 0;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.product-card__status.is-online {
  background: #ddf8ee;
  color: #0d9b7e;
}

.product-card__status.is-pending {
  background: #fff4ce;
  color: #8b641b;
}

.product-card__status.is-offline {
  background: #eef2f6;
  color: #7a8494;
}

.product-card__sub {
  margin-top: 8rpx;
  color: #617084;
  font-size: 24rpx;
  line-height: 1.45;
}

.product-card__prices {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.price-item {
  min-width: 0;
  padding: 18rpx 14rpx;
  border-radius: 14rpx;
  background: #f7f9fb;
}

.price-item__label {
  font-size: 22rpx;
  color: #617084;
}

.price-item__value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #17202f;
  word-break: break-all;
}

.price-item__value--price {
  color: #9a6c13;
}

.price-item__value--profit {
  color: #0d9b7e;
}

.price-item__value--loss {
  color: #df4f43;
}

.product-card__foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  gap: 18rpx;
}

.product-card__meta {
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  gap: 10rpx 14rpx;
}

.meta-text {
  font-size: 23rpx;
  color: #617084;
}

.product-card__switch {
  display: flex;
  flex-shrink: 0;
  align-items: center;
}
