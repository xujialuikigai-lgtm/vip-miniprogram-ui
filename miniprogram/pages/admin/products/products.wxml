<!-- 管理端 - 商品运营列表页 -->
<view class="page-products">
  <view class="ops-hero">
    <view class="ops-hero__title">商品 / 分类 / 套餐</view>
    <view class="ops-hero__desc">配置接口商品、成本售价、自动开通和上下架状态。</view>

    <view class="overview">
      <view class="overview__item">
        <view class="overview__num">{{stats.total}}</view>
        <view class="overview__label">全部商品</view>
      </view>
      <view class="overview__item">
        <view class="overview__num overview__num--on">{{stats.online}}</view>
        <view class="overview__label">已上架</view>
      </view>
      <view class="overview__item">
        <view class="overview__num overview__num--off">{{stats.offline}}</view>
        <view class="overview__label">已下架</view>
      </view>
    </view>

    <view class="actions">
      <button
        class="actions__btn actions__btn--gold"
        loading="{{syncing}}"
        disabled="{{syncing}}"
        bindtap="onSync"
      >
        {{syncing ? '同步中' : '同步商品'}}
      </button>
      <button class="actions__btn actions__btn--plain" bindtap="onAddProduct">
        新增商品
      </button>
    </view>
  </view>

  <view class="products-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="products-tab {{activeTab === item.value ? 'products-tab--active' : ''}}"
      data-value="{{item.value}}"
      bindtap="onTabTap"
    >
      {{item.label}}
    </view>
  </view>

  <view class="container">
    <skeleton
      wx:if="{{state === 'loading'}}"
      loading="{{true}}"
      type="card"
      rows="{{4}}"
      bind:retry="onRetry"
    />

    <block wx:elif="{{state === 'success'}}">
      <view
        class="product-card"
        wx:for="{{list}}"
        wx:key="productId"
        data-id="{{item.productId}}"
        bindtap="onCardTap"
      >
        <view class="product-card__head">
          <view class="product-card__name">{{item.name}}</view>
          <view class="product-card__status {{item.online ? 'is-online' : item.pendingConfig ? 'is-pending' : 'is-offline'}}">
            {{item.statusText}}
          </view>
        </view>

        <view class="product-card__sub">
          {{item.categoryName || '未分类'}} · 接口商品ID：{{item.shunshiGoodsId || '-'}}
        </view>

        <view class="product-card__prices">
          <view class="price-item">
            <text class="price-item__label">默认售价</text>
            <text class="price-item__value price-item__value--price">{{item.price > 0 ? '¥' + item.priceText : '待配置'}}</text>
          </view>
          <view class="price-item">
            <text class="price-item__label">接口成本</text>
            <text class="price-item__value">{{item.costPrice > 0 ? '¥' + item.costText : '-'}}</text>
          </view>
          <view class="price-item">
            <text class="price-item__label">单单利润</text>
            <text class="price-item__value {{item.loss ? 'price-item__value--loss' : 'price-item__value--profit'}}">{{item.price > 0 ? '¥' + item.profitText : '-'}}</text>
          </view>
        </view>

        <view class="product-card__foot">
          <view class="product-card__meta">
            <text class="meta-text">可售套餐：{{item.sellablePackages || 0}}</text>
            <text class="meta-text">待配置：{{item.pendingPackages || 0}}</text>
            <text class="meta-text">今日销量：{{item.todaySales}}</text>
          </view>
          <view class="product-card__switch" catchtap="noop">
            <t-switch
              value="{{item.online}}"
              disabled="{{togglingId === item.productId}}"
              data-id="{{item.productId}}"
              data-name="{{item.name}}"
              bind:change="onToggleOnline"
            />
          </view>
        </view>
      </view>
    </block>

    <empty-state
      wx:elif="{{state === 'empty'}}"
      icon="📦"
      description="暂无商品"
      tip="点击上方「同步商品」从接口拉取，或「新增商品」手动添加"
      button-text="同步商品"
      bind:action="onSync"
    />

    <empty-state
      wx:elif="{{state === 'error'}}"
      icon="📡"
      description="加载失败"
      tip="请检查网络或权限后重试"
      button-text="重新加载"
      bind:action="onRetry"
    />
  </view>
</view>
