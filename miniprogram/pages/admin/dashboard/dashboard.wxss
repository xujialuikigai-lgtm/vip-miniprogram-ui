/* 管理端看板样式 */
.page-admin-dashboard {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
  /* 主题色变量，供 TDesign 子组件继承 */
  --td-brand-color: #c99a3a;
}

/* ============ 核心指标卡片 ============ */
.cards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.card {
  width: calc(50% - 8rpx);
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card__value {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.card__unit {
  font-size: 24rpx;
  font-weight: 500;
  margin-left: 4rpx;
}

.card__label {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #999999;
}

.quick-actions {
  margin-top: 24rpx;
}

.quick-action {
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.quick-action__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.quick-action__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

/* ============ 通用面板 ============ */
.panel {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.panel__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.panel__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.panel__sub {
  font-size: 24rpx;
  color: #bbbbbb;
}

.panel__empty {
  padding: 40rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #bbbbbb;
}

/* ============ 趋势柱状图 ============ */
.legend {
  display: flex;
  gap: 24rpx;
}

.legend__item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #999999;
}

.legend__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.legend__dot--sales {
  background: #c99a3a;
}

.legend__dot--count {
  background: #2196f3;
}

.chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 280rpx;
}

.chart__col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.chart__bars {
  flex: 1;
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
  height: 100%;
}

.chart__bar {
  width: 16rpx;
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
  transition: height 0.3s ease;
}

.chart__bar--sales {
  background: #c99a3a;
}

.chart__bar--count {
  background: #2196f3;
}

.chart__amount {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #c99a3a;
}

.chart__date {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #bbbbbb;
}

/* ============ 分类占比 ============ */
.ratio {
  margin-bottom: 24rpx;
}

.ratio:last-child {
  margin-bottom: 0;
}

.ratio__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.ratio__name {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #333333;
}

.ratio__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.ratio__val {
  font-size: 24rpx;
  color: #999999;
}

.ratio__track {
  height: 14rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  overflow: hidden;
}

.ratio__fill {
  height: 100%;
  border-radius: 8rpx;
  min-width: 8rpx;
  transition: width 0.3s ease;
}

/* ============ 销量排行 ============ */
.rank {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rank:last-child {
  border-bottom: none;
}

.rank__no {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 24rpx;
  color: #999999;
  background: #f0f0f0;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank__no--top {
  color: #ffffff;
  background: #c99a3a;
  font-weight: 600;
}

.rank__name {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.rank__count {
  font-size: 26rpx;
  color: #c99a3a;
  font-weight: 600;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ============ 待办订单 ============ */
.todo-tabs {
  margin-bottom: 8rpx;
}

.todo-tabs__active {
  color: #c99a3a !important;
  font-weight: 600;
}

.todo {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.todo:last-child {
  border-bottom: none;
}

.todo__main {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.todo__name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.todo__meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #bbbbbb;
}

.todo__right {
  text-align: right;
  flex-shrink: 0;
}

.todo__status {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
}

.todo__amount {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #666666;
}

/* ============ 审计日志 ============ */
.log {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.log:last-child {
  border-bottom: none;
}

.log__line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.log__operator {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
}

.log__time {
  font-size: 22rpx;
  color: #bbbbbb;
}

.log__action {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #666666;
}

.log__note {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #999999;
}
