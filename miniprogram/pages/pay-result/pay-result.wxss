/* 支付结果页样式 */
.page-pay-result {
  min-height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  background:
    linear-gradient(rgba(20, 184, 166, 0.04) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(20, 184, 166, 0.04) 1rpx, transparent 1rpx),
    #f5f7f8;
  background-size: 40rpx 40rpx;
}

/* 加载/异常态居中块 */
.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
}

.state-block__text {
  margin: 24rpx 0 32rpx;
  font-size: 28rpx;
  color: #999999;
}

.state-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.state-icon--muted {
  background: #eef2f6;
  color: #8a95a5;
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 24rpx;
  padding: 66rpx 34rpx 34rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(21, 32, 51, 0.05);
}

.result-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: #12aa9c;
  box-shadow: 0 16rpx 34rpx rgba(18, 170, 156, 0.22);
  color: #ffffff;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1;
}

.result-title {
  margin-top: 28rpx;
  font-size: 40rpx;
  font-weight: 800;
  color: #17202f;
}

.result-subtitle {
  margin: 18rpx 22rpx 28rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #617084;
  text-align: center;
}

.result-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  width: 100%;
  margin-top: 24rpx;
}

.result-btn {
  height: 76rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
  padding: 0;
}

.result-btn::after {
  border: none;
}

.result-btn--plain {
  border: 1rpx solid #dfe6ed;
  background: #ffffff;
  color: #526071;
}

.result-btn--gold {
  background: #fff1bf;
  color: #8b641b;
}

/* 通用卡片 */
.card {
  margin: 24rpx 24rpx 0;
  padding: 28rpx 28rpx 12rpx;
  background-color: #ffffff;
  border-radius: 18rpx;
}

.card--alert {
  padding-bottom: 28rpx;
}

.card__title {
  font-size: 30rpx;
  font-weight: 800;
  color: #17202f;
  margin-bottom: 20rpx;
}

.card__title--alert {
  color: #e45c4f;
}

.card__title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card__title-row .card__title {
  margin-bottom: 0;
}

/* 订单摘要行 */
.summary-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-row__label {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #617084;
  margin-right: 24rpx;
}

.summary-row__value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #17202f;
  word-break: break-all;
}

.summary-row__value--amount {
  color: #c99a3a;
  font-weight: 800;
}

.summary-row__value--status {
  color: #12aa9c;
  font-weight: 800;
}

.summary-row__value--copy {
  font-weight: 800;
}

/* 失败原因 */
.alert-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}
