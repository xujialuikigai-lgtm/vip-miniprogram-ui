/* 支付结果页样式 */
.page-pay-result {
  min-height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 加载/异常态居中块 */
.state-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
}

.state-block__text {
  margin: 24rpx 0 32rpx;
  font-size: 28rpx;
  color: #999999;
}

/* Hero 区：主题金色渐变 */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 64rpx;
  background: linear-gradient(135deg, #d4a847 0%, #c99a3a 100%);
  color: #ffffff;
}

.hero__icon {
  margin-bottom: 16rpx;
}

.hero__title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.hero__subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  text-align: center;
}

.hero__amount {
  margin-top: 28rpx;
  font-size: 56rpx;
  font-weight: 700;
}

/* 通用卡片 */
.card {
  margin: 24rpx 24rpx 0;
  padding: 28rpx 28rpx 8rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
}

.card--alert {
  padding-bottom: 28rpx;
}

.card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.card__title--alert {
  color: #e45c4f;
}

.card__title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card__title-row .card__title {
  margin-bottom: 0;
}

/* 订单摘要行 */
.summary-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-row__label {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #999999;
  margin-right: 24rpx;
}

.summary-row__value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333333;
  word-break: break-all;
}

.summary-row__value--amount {
  color: #c99a3a;
  font-weight: 600;
}

.summary-row__value--copy {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.summary-row__copy-tip {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #c99a3a;
}

/* 失败原因 */
.alert-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 底部操作 */
.footer {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 40rpx 24rpx 0;
}

.footer__btn {
  width: 100%;
}
