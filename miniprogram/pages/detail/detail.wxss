/* 商品详情页样式 */
.page-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

/* —— 品牌 Hero 区 —— */
.hero {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #fff7e8 0%, #ffffff 100%);
}

.hero__icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: #fff;
  flex-shrink: 0;
}

.hero__icon--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 600;
  color: #c99a3a;
  background: #f5f0e6;
}

.hero__info {
  margin-left: 24rpx;
  flex: 1;
  overflow: hidden;
}

.hero__name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.hero__tags {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
}

.hero__tag {
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.hero__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

/* —— 通用区块 —— */
.section {
  margin: 20rpx 24rpx;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
}

.section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

/* —— 会员类型 —— */
.member-types {
  display: flex;
  flex-wrap: wrap;
}

.member-type {
  padding: 16rpx 36rpx;
  margin: 0 20rpx 20rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.member-type--active {
  color: #c99a3a;
  background: #fbf3e1;
  border-color: #c99a3a;
  font-weight: 600;
}

/* —— 套餐选择 —— */
.packages {
  display: flex;
  flex-wrap: wrap;
}

.package {
  position: relative;
  width: 210rpx;
  margin: 0 18rpx 18rpx 0;
  padding: 24rpx 16rpx;
  text-align: center;
  background: #f9f9f9;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
}

.package:nth-child(3n) {
  margin-right: 0;
}

.package--active {
  background: #fbf3e1;
  border-color: #c99a3a;
}

.package__name {
  font-size: 26rpx;
  color: #333;
}

.package__price {
  margin-top: 12rpx;
  color: #c99a3a;
  font-weight: 600;
}

.package__symbol {
  font-size: 24rpx;
}

.package__value {
  font-size: 40rpx;
}

.package__origin {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #bbb;
  text-decoration: line-through;
}

.package__badge {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  padding: 2rpx 12rpx;
  font-size: 20rpx;
  color: #fff;
  background: #c99a3a;
  border-radius: 0 14rpx 0 14rpx;
}

/* —— 关键须知 —— */
.rule {
  display: flex;
  padding: 12rpx 0;
  font-size: 26rpx;
  line-height: 1.6;
}

.rule__label {
  flex-shrink: 0;
  width: 120rpx;
  color: #999;
}

.rule__text {
  flex: 1;
  color: #333;
}

/* —— 权益对比表 —— */
.compare {
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.compare__head,
.compare__row {
  display: flex;
  align-items: center;
}

.compare__head {
  background: #faf6ed;
  font-weight: 600;
  color: #333;
}

.compare__row {
  border-top: 2rpx solid #f0f0f0;
}

.compare__cell {
  flex: 1;
  padding: 20rpx 12rpx;
  font-size: 26rpx;
  text-align: center;
  color: #555;
}

.compare__cell--name {
  flex: 1.4;
  text-align: left;
}

.compare__cell--price {
  color: #c99a3a;
  font-weight: 600;
}

.compare__cell--origin {
  color: #bbb;
}

/* —— 底部占位 + 固定支付栏 —— */
.bottom-holder {
  height: 220rpx;
}

.paybar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.paybar__form {
  max-height: 460rpx;
  overflow-y: auto;
  padding: 8rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.paybar__action {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
}

.paybar__amount {
  flex: 1;
  display: flex;
  align-items: baseline;
  color: #c99a3a;
}

.paybar__amount-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
}

.paybar__amount-symbol {
  font-size: 28rpx;
  font-weight: 600;
}

.paybar__amount-value {
  font-size: 44rpx;
  font-weight: 700;
}

.paybar__btn {
  width: 280rpx;
}
