/* 搜索结果页样式 */
.page-search {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部搜索框（吸顶） */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
}

/* 排序 Tab 容器 */
.sort-tabs {
  position: sticky;
  top: 96rpx;
  z-index: 9;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 选中态文字使用主题色 */
.sort-tabs__active {
  color: #c99a3a !important;
  font-weight: 600;
}

/* 结果提示条："找到 X 个相关会员权益" */
.result-tip {
  padding: 20rpx 32rpx;
  font-size: 26rpx;
  color: #888888;
}

.result-tip {
  /* 强调数量主题色由整体文案承载，保持低调 */
  letter-spacing: 1rpx;
}

.container {
  padding: 0 24rpx 32rpx;
}

/* 结果列表 */
.result-list {
  display: flex;
  flex-direction: column;
}

.result-list__item {
  display: block;
  margin-bottom: 20rpx;
}

.inline-product-card {
  display: flex;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.inline-product-card__icon {
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
  margin-right: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.inline-product-card__icon--text {
  background: #c99a3a;
  color: #fff;
  font-size: 42rpx;
  font-weight: 700;
}

.inline-product-card__body {
  flex: 1;
  min-width: 0;
}

.inline-product-card__name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.inline-product-card__meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.inline-product-card__footer {
  margin-top: 14rpx;
}

.inline-product-card__price {
  color: #c99a3a;
  font-size: 34rpx;
  font-weight: 700;
}

.inline-product-card__pending {
  display: inline-flex;
  padding: 6rpx 14rpx;
  color: #9a6a18;
  background: #fbf3e1;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}
