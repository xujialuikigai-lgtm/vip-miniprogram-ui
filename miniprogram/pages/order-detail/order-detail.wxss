/* 订单详情页样式 */
.page-order-detail {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 32rpx;
}

/* 加载 / 异常占位 */
.state-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.state-text {
  margin: 24rpx 0 32rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 状态 Hero 区（暗色卡片） */
.hero {
  margin: 24rpx;
  padding: 40rpx 36rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #3a342a 0%, #1f1c17 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 28, 23, 0.2);
}

.hero__status {
  font-size: 40rpx;
  font-weight: 700;
  color: #f5d9a0;
}

.hero__desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.78);
}

/* 失败原因 */
.hero__fail {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 90, 70, 0.16);
}

.hero__fail-text {
  margin-left: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #ffb4a8;
}

/* 三指标 */
.hero__metrics {
  display: flex;
  margin-top: 36rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}

.metric {
  flex: 1;
  text-align: center;
}

.metric--mid {
  border-left: 1rpx solid rgba(255, 255, 255, 0.12);
  border-right: 1rpx solid rgba(255, 255, 255, 0.12);
}

.metric__value {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.metric__label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 通用卡片 */
.card {
  margin: 24rpx;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
}

.card__title {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row__label {
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
}

.info-row__value {
  display: flex;
  align-items: center;
}

.info-row__text {
  font-size: 26rpx;
  color: #333333;
  margin-right: 8rpx;
  word-break: break-all;
  text-align: right;
}

/* 温馨提示 */
.notice__item {
  font-size: 24rpx;
  line-height: 1.8;
  color: #999999;
}

/* 底部占位与固定操作栏 */
.bottom-placeholder {
  height: 140rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.footer__btn {
  flex: 1;
}

.footer__btn--plain {
  flex: 0 0 200rpx;
}
