/* 分类页，贴近原型左右双栏 */
.page-category {
  height: 100vh;
  background: #f5f7f8;
  box-sizing: border-box;
}

.category-skeleton {
  padding: 24rpx;
}

.category-error {
  padding-top: 160rpx;
}

.category-top {
  padding: 24rpx 24rpx 0;
}

.category-search {
  height: 88rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 24rpx;
  color: #4b5c6e;
  background: #fbfcfc;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 0 rgba(16, 23, 36, 0.03);
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.category-filter-tip {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  color: #315d58;
  background: #eefaf7;
  border: 2rpx solid rgba(15, 159, 143, 0.22);
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.category-filter-tip__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0f9f8f;
}

.category-layout {
  display: grid;
  grid-template-columns: 172rpx 1fr;
  gap: 20rpx;
  height: calc(100vh - 204rpx);
  padding: 20rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.category-side {
  width: 172rpx;
  height: 100%;
  box-sizing: border-box;
}

.category-side__item {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  padding: 0 16rpx;
  color: #566173;
  background: rgba(255, 255, 255, 0.76);
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.category-side__item--active {
  color: #8f6418;
  background: #fff3cf;
  border-color: rgba(201, 154, 58, 0.42);
}

.category-side__text {
  line-height: 1.35;
}

.category-main {
  height: 100%;
  background: transparent;
  box-sizing: border-box;
}

.category-main__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 4rpx 0 20rpx;
}

.category-main__title {
  color: #17202f;
  font-size: 34rpx;
  font-weight: 900;
}

.category-main__count {
  color: #8a919b;
  font-size: 24rpx;
  font-weight: 700;
}

.category-main__skeleton {
  padding: 12rpx 0;
}

.category-main__error,
.category-main__empty {
  padding-top: 120rpx;
}

.category-main__list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 0 40rpx;
}

.category-main__card {
  display: block;
}

.category-main__loadmore,
.category-main__nomore {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  color: #8a919b;
  font-size: 24rpx;
}
