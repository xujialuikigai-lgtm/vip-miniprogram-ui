/* 首页，贴近 vip-miniprogram-ui.html 的产品型视觉 */
.page-index {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  box-sizing: border-box;
  background: #f5f7f8;
}

.search-bar {
  padding: 0;
}

.search-box {
  display: flex;
  align-items: center;
  height: 84rpx;
  padding: 0 24rpx;
  background: #fbfcfc;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 0 rgba(16, 23, 36, 0.03);
}

.search-icon {
  color: #7a8494;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.search-placeholder {
  margin-left: 14rpx;
  font-size: 28rpx;
  color: #4b5c6e;
}

.trust-hero {
  position: relative;
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  overflow: hidden;
  color: #fbfcfc;
  border-radius: 16rpx;
  border: 2rpx solid rgba(78, 232, 208, 0.16);
  background:
    radial-gradient(circle at 82% 16%, rgba(78, 232, 208, 0.38), transparent 28%),
    radial-gradient(circle at 6% 100%, rgba(201, 154, 58, 0.32), transparent 34%),
    linear-gradient(135deg, #111a28, #143831 58%, #101724);
  box-shadow: 0 28rpx 56rpx rgba(15, 66, 77, 0.18);
}

.trust-hero__title {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 900;
}

.trust-hero__desc {
  margin-top: 14rpx;
  color: rgba(251, 252, 252, 0.9);
  font-size: 24rpx;
  line-height: 1.45;
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-item {
  min-width: 0;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.14);
}

.hero-value {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.15;
  color: #ffffff;
}

.hero-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.86);
}

.tabs {
  white-space: nowrap;
  margin: 24rpx -24rpx 20rpx;
  padding: 0 24rpx 4rpx;
  background: transparent;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 124rpx;
  height: 64rpx;
  margin-right: 16rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  color: #4b5565;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.tab-item--active {
  color: #8f6418;
  background: #fff3cf;
  border-color: rgba(201, 154, 58, 0.42);
}

.product-area {
  padding: 0;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 34rpx 0;
}

.list-end {
  font-size: 24rpx;
  color: #8a919b;
}
