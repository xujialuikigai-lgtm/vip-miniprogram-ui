/* 订单列表页样式 */
.page-orders {
  min-height: 100vh;
  background:
    linear-gradient(rgba(20, 184, 166, 0.04) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(20, 184, 166, 0.04) 1rpx, transparent 1rpx),
    #f5f7f8;
  background-size: 40rpx 40rpx;
  /* 主题色变量，供子组件继承 */
  --td-brand-color: #c99a3a;
}

/* 状态筛选 Tab：吸顶展示 */
.orders-tabs {
  position: sticky;
  top: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 22rpx 24rpx 18rpx;
  background: rgba(245, 247, 248, 0.96);
  backdrop-filter: blur(12rpx);
}

.orders-tab {
  height: 64rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #566276;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
}

.orders-tab--active {
  border: 1rpx solid #eac86f;
  background: #fff4ce;
  color: #8b641b;
}

/* 列表容器：底部留白，避免最后一张卡片贴边 */
.container {
  padding: 6rpx 0 48rpx;
}

/* 触底加载提示 */
.orders-loadmore {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  color: #999999;
  font-size: 24rpx;
}

/* 到底文案 */
.orders-end {
  text-align: center;
  padding: 24rpx 0;
  color: #bbbbbb;
  font-size: 24rpx;
}
