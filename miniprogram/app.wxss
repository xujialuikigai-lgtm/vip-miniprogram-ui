/* 全局样式 */

/* TDesign 自定义主题色覆盖 */
page {
  --td-brand-color: #c99a3a;
  --td-brand-color-light: rgba(201, 154, 58, 0.1);
  --td-brand-color-focus: rgba(201, 154, 58, 0.2);
  --td-brand-color-active: #b38834;
  --td-brand-color-disabled: rgba(201, 154, 58, 0.4);

  --td-success-color: #0f9f8f;
  --td-success-color-light: rgba(15, 159, 143, 0.1);
  --td-success-color-focus: rgba(15, 159, 143, 0.2);
  --td-success-color-active: #0d8a7c;
  --td-success-color-disabled: rgba(15, 159, 143, 0.4);

  --td-error-color: #e45c4f;
  --td-error-color-light: rgba(228, 92, 79, 0.1);
  --td-error-color-focus: rgba(228, 92, 79, 0.2);
  --td-error-color-active: #cc5246;
  --td-error-color-disabled: rgba(228, 92, 79, 0.4);

  --td-warning-color: #ff8a3d;
  --td-warning-color-light: rgba(255, 138, 61, 0.1);
  --td-warning-color-focus: rgba(255, 138, 61, 0.2);
  --td-warning-color-active: #e67c37;
  --td-warning-color-disabled: rgba(255, 138, 61, 0.4);

  /* 基础样式 */
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}
