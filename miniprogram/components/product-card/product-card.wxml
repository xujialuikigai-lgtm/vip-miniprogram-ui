<!-- 商品卡片组件：展示品牌图标、名称、标签、销量、现价与划线原价 -->
<view
  class="product-card {{compact ? 'product-card--compact' : ''}}"
  hover-class="product-card--hover"
  hover-stay-time="80"
  bindtap="onTap"
  aria-role="button"
  aria-label="{{product.name}}"
>
  <!-- 品牌图标，加载失败时展示名称首字占位 -->
  <view class="product-card__media">
    <image
      wx:if="{{displayIcon && !iconError}}"
      class="product-card__icon"
      src="{{displayIcon}}"
      mode="aspectFill"
      lazy-load="{{true}}"
      binderror="onIconError"
    />
    <view wx:else class="product-card__icon product-card__icon--placeholder">
      {{product.name ? product.name[0] : '会'}}
    </view>
  </view>

  <!-- 商品信息主体 -->
  <view class="product-card__body">
    <view class="product-card__name">{{product.name}}</view>

    <!-- 标签 -->
    <view class="product-card__tags">
      <block wx:if="{{product.tags && product.tags.length > 0}}">
        <text
          wx:for="{{product.tags}}"
          wx:key="*this"
          wx:if="{{index < 3}}"
          class="product-card__tag"
        >{{item}}</text>
      </block>
      <block wx:else>
        <text class="product-card__tag">权益直充</text>
        <text class="product-card__tag">失败退款</text>
      </block>
    </view>

    <view class="product-card__meta">{{salesText || '订单可查'}}｜不自动续费</view>

    <!-- 价格与销量 -->
    <view class="product-card__footer">
      <view class="product-card__price">
        <block wx:if="{{pricePending}}">
          <text class="product-card__pending">{{displayPrice}}</text>
        </block>
        <block wx:else>
          <text class="product-card__price-symbol">¥</text>
          <text class="product-card__price-value">{{displayPrice}}</text>
        </block>
        <text wx:if="{{showOriginalPrice}}" class="product-card__price-origin">¥{{displayOriginalPrice}}</text>
      </view>
      <view class="product-card__action">{{pricePending ? '待配置' : '查看详情'}}</view>
    </view>
  </view>
</view>
