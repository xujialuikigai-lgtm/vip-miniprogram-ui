/* 商品卡片组件样式，主题色 #c99a3a */

.product-card {
  display: flex;
  align-items: stretch;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

/* 点击态反馈 */
.product-card--hover {
  background-color: #faf7f0;
}

/* 品牌图标区域 */
.product-card__media {
  flex-shrink: 0;
  width: 120rpx;
  height: 120rpx;
  margin-right: 24rpx;
}

.product-card__icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
}

/* 图标加载失败占位 */
.product-card__icon--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  background-color: #c99a3a;
}

/* 信息主体 */
.product-card__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* 商品名称，最多两行省略 */
.product-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 标签区 */
.product-card__tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.product-card__tag {
  margin-right: 12rpx;
  margin-top: 4rpx;
}

/* 底部价格与销量 */
.product-card__footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 12rpx;
}

.product-card__price {
  display: flex;
  align-items: baseline;
  color: #c99a3a;
}

.product-card__price-symbol {
  font-size: 24rpx;
  font-weight: 600;
}

.product-card__price-value {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
  margin-left: 2rpx;
}

/* 划线原价 */
.product-card__price-origin {
  font-size: 24rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

/* 销量 */
.product-card__sales {
  font-size: 24rpx;
  color: #999999;
}
