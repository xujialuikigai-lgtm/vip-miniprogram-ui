/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

/* emoji/文本图标 */
.empty-state__icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 32rpx;
  opacity: 0.85;
}

/* 图片图标 */
.empty-state__icon-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

/* 主文案 */
.empty-state__desc {
  font-size: 30rpx;
  color: #666666;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

/* 辅助说明 */
.empty-state__tip {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.5;
}

/* 引导按钮，使用品牌金色主题（继承 TDesign 主题色 #c99a3a） */
.empty-state__btn {
  margin-top: 48rpx;
  min-width: 280rpx;
}
