/* 订单卡片样式 */
.order-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 26rpx 26rpx 24rpx;
  margin: 18rpx 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(21, 32, 51, 0.05);
}

/* 顶部：订单号 + 状态 */
.order-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.order-card__status {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 36rpx;
}

/* 中部：商品信息 */
.order-card__body {
  padding: 16rpx 0 4rpx;
}

.order-card__name {
  flex: 1;
  font-size: 31rpx;
  font-weight: 800;
  color: #17202f;
  line-height: 1.35;
}

.order-card__row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  font-size: 25rpx;
  line-height: 1.8;
}

.order-card__label {
  color: #617084;
  flex-shrink: 0;
}

.order-card__value {
  color: #536175;
  word-break: break-all;
}

.order-card__split {
  margin: 0 10rpx;
  color: #c8d0da;
}

/* 底部：金额 + 操作 */
.order-card__footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: 12rpx;
}

/* 操作按钮区 */
.order-card__actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.order-card__btn {
  min-width: 136rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.order-card__btn::after {
  border: none;
}

.order-card__btn--plain {
  border: 1rpx solid #dfe6ed;
  background: #ffffff;
  color: #526071;
}

.order-card__btn--gold {
  background: #fff1bf;
  color: #8b641b;
}
