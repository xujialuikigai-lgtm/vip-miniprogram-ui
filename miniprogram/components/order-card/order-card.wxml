<!-- 订单卡片 -->
<view class="order-card" bindtap="onCardTap">
  <view class="order-card__header">
    <view class="order-card__name">{{displayName}}</view>
    <text class="order-card__status" style="color:{{statusColor}};">{{statusText}}</text>
  </view>

  <view class="order-card__body">
    <view class="order-card__row" wx:if="{{maskedAccount}}">
      <text class="order-card__label">充值账号：</text>
      <text class="order-card__value">{{maskedAccount}}</text>
    </view>
    <view class="order-card__row">
      <text class="order-card__label">订单号：</text>
      <text class="order-card__value">{{order.orderId}}</text>
    </view>
    <view class="order-card__row">
      <text class="order-card__label">支付金额：</text>
      <text class="order-card__value">¥{{displayAmount}}</text>
      <text class="order-card__split">|</text>
      <text class="order-card__label">下单时间：</text>
      <text class="order-card__value">{{displayTime}}</text>
    </view>
  </view>

  <view class="order-card__footer">
    <view class="order-card__actions" catchtap="catchActionTap">
      <button
        wx:if="{{showRefresh}}"
        class="order-card__btn order-card__btn--plain"
        loading="{{refreshing}}"
        disabled="{{refreshing}}"
        bindtap="onRefreshTap"
      >
        {{refreshing ? '刷新中' : '查看进度'}}
      </button>

      <button
        wx:if="{{showRebuy}}"
        class="order-card__btn order-card__btn--gold"
        bindtap="onRebuyTap"
      >
        再买一次
      </button>
    </view>
  </view>
</view>
