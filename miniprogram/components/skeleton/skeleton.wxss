/* 骨架屏样式 */
.skeleton {
  padding: 16rpx 24rpx;
}

/* ---------- 列表型 ---------- */
.skeleton__list {
  display: flex;
  flex-direction: column;
}

.skeleton__row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.skeleton__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.skeleton__lines {
  flex: 1;
}

/* ---------- 卡片型 ---------- */
.skeleton__cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.skeleton__card {
  width: 48%;
  padding: 16rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.skeleton__cover {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

/* ---------- 文本型 ---------- */
.skeleton__text {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

/* ---------- 占位线条 ---------- */
.skeleton__line {
  height: 28rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.skeleton__line--title {
  width: 60%;
  height: 32rpx;
}

.skeleton__line--text {
  width: 100%;
}

.skeleton__line--short {
  width: 40%;
  margin-bottom: 0;
}

/* ---------- 渐变流光动画 ---------- */
.skeleton__shine {
  /* 基础底色 + 流光高光，从左向右扫过 */
  background: linear-gradient(
    90deg,
    #ebedf0 25%,
    #f5f6f7 37%,
    #ebedf0 63%
  );
  background-size: 400% 100%;
  animation: skeleton-shine 1.4s ease infinite;
}

@keyframes skeleton-shine {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}

/* ---------- 超时异常态 ---------- */
.skeleton__error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 48rpx;
}

.skeleton__error-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.skeleton__error-text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.skeleton__error-tip {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.skeleton__retry {
  min-width: 200rpx;
}
